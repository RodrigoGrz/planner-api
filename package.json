{
  "name": "planner",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "private": true,
  "scripts": {
    "start": "node dist/server.cjs",
    "dev:start": "tsx --watch src/server.ts",
    "build": "tsup src --format cjs",
    "test": "vitest run",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "keywords": [],
  "author": "Rodrigo Grzegorczyk <rodrigo.gregorio1@hotmail.com>",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "3.1011.0",
    "@fastify/cors": "11.2.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "9.4.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.5.0",
    "bcryptjs": "3.0.3",
    "dayjs": "1.11.20",
    "dotenv": "17.3.1",
    "fastify": "5.8.2",
    "fastify-type-provider-zod": "6.1.0",
    "nodemailer": "6.9.13",
    "zod": "4.3.6"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@faker-js/faker": "10.3.0",
    "@rocketseat/eslint-config": "^2.2.2",
    "@types/node": "25.5.0",
    "@types/nodemailer": "7.0.11",
    "@types/supertest": "7.2.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vitest-globals": "^1.5.0",
    "prisma": "7.5.0",
    "supertest": "7.2.2",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "unplugin-swc": "1.5.9",
    "vite": "7.3.0",
    "vite-tsconfig-paths": "6.0.3",
    "vitest": "4.0.16"
  },
  "eslintConfig": {
    "root": true,
